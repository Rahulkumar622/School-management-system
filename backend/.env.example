PORT=5000
# Optional: if set, the app can use a single MySQL connection URL instead of DB_HOST/DB_USER/etc.
MYSQL_URL=
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=school_db
DB_SSL=false
DB_CONNECTION_LIMIT=10
CLIENT_URL=http://localhost:3000
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=1234
JWT_SECRET=school-management-system-secret-key-change-in-production
# Optional notification provider placeholders
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=
